# ============================================================
# Almonte Plumbing — Environment Variables
# ============================================================
# DO NOT commit a populated version of this file.
# Copy to .env.local for local dev, set in Netlify UI for production.
# ============================================================

# ── Supabase (CRM + database) ─────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ── Square (payments + invoicing) ────────────────────────────
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_LOCATION_ID=your-location-id
SQUARE_WEBHOOK_SIGNATURE_KEY=your-webhook-signature-key
# EXACT webhook subscription URL registered in the Square dashboard.
# Square signs each event over (this URL + body), so it must match byte-for-byte.
# Prod:  https://almonteplumbing.com/.netlify/functions/square-webhook
# Local: your ngrok URL, e.g. https://abc123.ngrok-free.app/.netlify/functions/square-webhook
SQUARE_WEBHOOK_URL=https://almonteplumbing.com/.netlify/functions/square-webhook

# ── Twilio (SMS delivery) ─────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Email (invoice delivery) ──────────────────────────────────
# Using Resend (https://resend.com). Free tier ~100/day, 3,000/mo.
RESEND_API_KEY=your-resend-api-key
# FROM_EMAIL must be on a domain verified in Resend.
# For testing before verification, use onboarding@resend.dev (delivers only to your account email).
FROM_EMAIL=invoices@almonteplumbing.com
FROM_NAME=Almonte Plumbing

# ── Admin dashboard ───────────────────────────────────────────
ADMIN_PASSWORD=change-this-before-launch

# ── Site ──────────────────────────────────────────────────────
SITE_URL=https://almonteplumbing.com
